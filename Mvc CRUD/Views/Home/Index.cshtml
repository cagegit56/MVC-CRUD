                function startDrag(e) {
                    dragging = true;
                    startY = e.touches ? e.touches[0].clientY : e.clientY;
                    comments.style.transition = "none";

                    document.addEventListener("touchmove", drag);
                    document.addEventListener("mousemove", drag);
                    document.addEventListener("touchend", endDrag);
                    document.addEventListener("mouseup", endDrag);
                }

                function drag(e) {
                    if (!dragging) return;
                    currentY = e.touches?.[0]?.clientY ?? e.clientY;
                    const diff = currentY - startY;
                    if (diff > 0) comments.style.transform = `translateY(${diff}px)`;
                }

                function endDrag() {
                    dragging = false;
                    comments.style.transform = 'translateY(0)';
                    if (currentY - startY > 100)
                    {
                        comments.classList.remove("show");
                        hideBgContent.style.opacity = "0";
                        hideBgContent.style.pointerEvents = "none";
                        document.body.style.overflow = "";
                    } else {
                        comments.classList.add("show");
                        hideBgContent.style.opacity = "1";
                        hideBgContent.style.pointerEvents = "auto";
                        document.body.style.overflow = "hidden";

                    }

                    document.removeEventListener("touchmove", drag);
                    document.removeEventListener("mousemove", drag);
                    document.removeEventListener("touchend", endDrag);
                    document.removeEventListener("mouseup", endDrag);
