    function changeColor(color) {
        textarea = document.getElementById("textAreaBackground");
        textarea.style.backgroundColor = color;
        textarea.style.color = 'white';
        if(color === 'white')
        textarea.style.color = 'grey';
        document.getElementById("selectedColor").value = color;
    }

    document.getElementById("imageInput").addEventListener("change", function (e) {
        const previewContainer = document.getElementById('imagePreviewContainer');
        const preview = document.getElementById('imagePreview');

        if (e.target.files && e.target.files[0]) {
            const reader = new FileReader();

            reader.onload = (e) => {
                preview.src = e.target.result;
                document.getElementById('imagePic').value = e.target.result;
                previewContainer.style.display = 'block';
            };

            reader.readAsDataURL(e.target.files[0]);
        }
        const buttonColours = document.getElementById("mainButton");
        buttonColours.style.display = 'none';
        document.getElementById('imagePreview').value = e;
    });


    function clearImage() {
        document.getElementById('imagePreviewContainer').style.display = 'none';
        document.getElementById('imageInput').value = "";
        document.getElementById("mainButton").style.display = 'block';
    }

    function dateProcessing(unformattedDate){
        let timeFormat = "";
        const utcDate = new Date(unformattedDate);
        const nowSA = new Date(new Date().toLocaleString("en-US", {
            timeZone: "Africa/Johannesburg"
        }));
        const sentOnSA = new Date(utcDate.toLocaleString("en-US", {
            timeZone: "Africa/Johannesburg"
        }));
        const diffMs = nowSA - sentOnSA;
        const diffSeconds = Math.floor(diffMs / 1000);
        const diffMinutes = Math.floor(diffSeconds / 60);
        const diffHours = Math.floor(diffMinutes / 60);
        const diffDays = Math.floor(diffHours / 24);
        const diffWeeks = Math.floor(diffDays / 7);
        const diffMonths = Math.floor(diffDays / 30);
        const diffYears = Math.floor(diffDays / 365);

        if (diffSeconds < 60) {
            timeFormat = "just now";
        }
        else if (diffMinutes < 60) {
            timeFormat = `${diffMinutes}m`;
        }
        else if (diffHours < 24) {
            timeFormat = `${diffHours}h`;
        }
        else if (diffDays < 7) {
            timeFormat = `${diffDays}d`;
        }
        else if (diffWeeks < 5) {
            timeFormat = `${diffWeeks}w`;
        }
        else if (diffMonths <= 12) {
            timeFormat = `${diffMonths}mo`;
        }
        else if (diffYears <= 2) {
            timeFormat = `${diffYears}y`;
        }
        else {
            timeFormat = sentOnSA.toLocaleDateString();
        }

        return timeFormat;
    }

