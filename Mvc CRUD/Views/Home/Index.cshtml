@model List<Mvc_CRUD.Models.Posts>

@if (TempData["ErrorMessage"] == null)
{
    ViewData["Title"] = "ChatUp-Home";
    var initial = !string.IsNullOrEmpty(ViewBag.Username) ? ViewBag.Username.Substring(0, 1).ToUpper() : "XX";
    var userAgent = Context.Request.Headers["User-Agent"].ToString();
    bool isMobile = userAgent.Contains("Android", StringComparison.OrdinalIgnoreCase) || userAgent.Contains("iPhone", StringComparison.OrdinalIgnoreCase)
                    || userAgent.Contains("iPad", StringComparison.OrdinalIgnoreCase) || userAgent.Contains("Mobile", StringComparison.OrdinalIgnoreCase)
                    || userAgent.Contains("Mobi", StringComparison.OrdinalIgnoreCase);

<link href="~/css/site.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<div class="container mt-4 col-10">
    <div class="row">
        <div class="col-md-8 mx-auto">          
            <div class="card shadow-sm border-0 rounded-4 mb-2 gap-0">
                <div class="card-body">
                <div class="d-flex align-items-center gap-1 mb-2">                    
                    @if (!string.IsNullOrEmpty(@ViewBag.UserProfilePic))
                    {
                        <img src="@ViewBag.UserProfilePic" class="rounded-circle me-2 d-flex align-items-center justify-content-center"
                             style="width:45px; height:45px; object-fit: cover; cursor : pointer" />
                    }
                    else
                    {
                        <div class='avatar rounded-circle bg-primary text-white d-flex align-items-center justify-content-center'
                             style='width:45px; height:45px; font-size: 17px; font-weight: bold;'>
                            @initial
                        </div>
                    }
                    <button class="form-control text-start bg-light border-0 rounded-pill py-2" data-bs-toggle="modal" data-bs-target="#createPostModal">
                        <span class="text-muted">What's on your mind, @(char.ToUpper(@ViewBag.Username[0]) + @ViewBag.Username.Substring(1))?</span>
                    </button>
                </div>
                <div class="d-flex justify-content-between">
                    <button class="btn btn-light fw-bold" data-bs-toggle="modal" data-bs-target="#createPostModal">
                        <i class="bi bi-camera-video text-danger"></i> Live
                    </button>
                    <button class="btn btn-light fw-bold" data-bs-toggle="modal" data-bs-target="#createPostModal">
                        <i class="bi bi-images text-success"></i> Photo
                    </button>
                    <button class="btn btn-light fw-bold" data-bs-toggle="modal" data-bs-target="#createPostModal">
                        <i class="bi bi-emoji-smile text-warning"></i> Feeling
                    </button>
                </div>
            </div>
            </div>
            <br />            

            <div id="postContent"></div>
            @if (Model != null && Model.Any())
            {
                foreach (var post in Model)
                {
                    <div class="card shadow-sm border-0 rounded-4 mb-4 gap-0">
                    <div class="card-body p-0">
                        <div class="d-flex align-items-center mb-1 p-2">
                            @if(!string.IsNullOrEmpty(post.UserImageUrl))
                            {
                                <img src="@post.UserImageUrl" class="rounded-circle" style="width:45px;height:45px;object-fit:cover;" />
                            }
                            else
                            {
                                var usernameFirstLetter = post.UserName.Substring(0,1).ToUpper();
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold" style="width:45px;height:45px;">
                                    @usernameFirstLetter
                                </div>
                            }
                            <div class="col ms-1">
                                <h6 class="mb-0 fw-bold">
                                    @(char.ToUpper(@post.UserName[0]) + @post.UserName.Substring(1)) @(char.ToUpper(@post.LastName[0]) + @post.LastName.Substring(1))</h6>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>@post.CreatedOn.ToString("MMM dd, yyyy • h:mm tt")
                                </small>
                            </div>
                            <div class="dropdown ms-auto" id="dropdown-@post.Id">
                                <button class="btn fw-bolder" type="button" data-action="ToggleDropDownMenu" data-id="@post.Id">
                                    &#8230;
                                </button>
                                <ul class="dropdown-menu custom-dropdown" id="dropDownMenu-@post.Id">
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-pencil me-2"></i>Edit Post</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-share me-2"></i>Share</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                </ul>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(post.PostBgColour))
                        {
                            <div class="post-bgcard" style="background-color: @post.PostBgColour">
                                <div class="post-bgtext p-2">@post.Content</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(post.Content) && string.IsNullOrEmpty(post.PostBgColour) )
                        {
                            <span class="p-2">@post.Content</span>
                        }
                        @if (!string.IsNullOrEmpty(post.ImageContentUrl))
                        {
                            <img src="@post.ImageContentUrl" class="post-image img-fluid rounded mb-0" style="width : 100%; max-height : 450px;  object-fit: cover;" alt="Post image">
                        }
                        <div class="d-flex justify-content-between text-muted">
                            <div>
                                <span class="me-3"> <i class="bi bi-heart-fill text-danger me-1"></i>
                                    <span>@post.likes</span>
                                </span>
                            </div>
                            <div>
                                <span>
                                    @if (@post.TotalComments != null && @post.TotalComments > 0)
                                    {
                                        <span>@post.TotalComments</span>
                                    }
                                    <i class="bi bi-chat me-1"></i>
                                </span>
                                <span>
                                    @if (@post.Comments != null && @post.Comments.Any())
                                    {
                                        <span>@post.Shares</span>
                                    }
                                    <i class="fa-solid fa-share"></i>
                                </span>
                            </div>
                        </div>
                        <hr class="dropdown mt-2 mb-0">
                        <div class="d-flex justify-content-around mb-1 p-2">
                            <button class="btn btn-link w-100 me-2 text-decoration-none text-muted like-btn @(post.Isliked ? "active" : "")" data-action="Like" data-id="@post.Id">
                                <i class="bi @(post.Isliked ? "bi-hand-thumbs-up-fill" : "bi-hand-thumbs-up")"></i> Like</button>
                            <button class="btn btn-link w-100 me-2 text-decoration-none text-muted" data-action="CommentsToggle" data-id="@post.Id">
                                <i class="bi  bi-chat"></i> Comment</button>
                            <button class="btn btn-link w-100 text-decoration-none text-muted" data-action="Share" data-id="@post.Id">
                                <i class="bi  bi-share"></i> Share
                            </button>
                        </div>
                        @* *************** Comments *********** *@
                        @if (isMobile)
                        {
                            <div class="overlay" id="overlay-@post.Id"></div>
                            <div class="comment-pop-up" id="commentsPopUp-@post.Id">
                                <div class="dragHandle" id="dragHandle-@post.Id"></div>
                                <div class="overflow-auto mt-4 w-100 " style="max-height: 340px;">
                                    <div id="displayMobileComments-@post.Id"></div>
                                     <div id="sendCommentBtn-@post.Id"></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="reply-group-@post.Id collapse mt-3 mb-2" id="commentsContents-@post.Id">
                                <div class="overflow-auto mb-2 p-2" id="displayer-@post.Id" style="max-height: 350px"></div>
                                    <div id="sendCommentBtn-@post.Id"></div>
                            </div>
                        }
                    </div>
                    </div>  
                }
            }
            else
            {
               <div class="text-center py-5">
                   <div class="display-1 text-muted mb-3">
                       <i class="bi bi-chat-square-text"></i>
                   </div>
                   <h3 class="mb-3">NO Post Yet Incoming Soon....................</h3>
                   <p class="text-muted mb-4">Exciting news : thought provoking post are on the way wait to be woooowed </p>
                   <button class="btn btn-primary btn-lg action-btn" data-bs-toggle="modal" data-bs-target="#createPostModal">
                        <i class="bi bi-plus-circle me-2"></i>Create First Post
                   </button>
               </div>
            }
        </div>
    </div>    
</div>

<!-- Create Post Modal -->
<div class="modal fade" id="createPostModal" tabindex="-1" >
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header gradient-bg d-flex justify-content-center position-relative">
                <h5 class="modal-title text-muted fw-bold">Create Post</h5>
                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Home" asp-action="CreatePost" method="post" data-action="PostForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="col align-items-center gap-2 mb-2">
                        <div class="d-flex gap-1">
                            <div class='avatar rounded-circle bg-primary text-white d-flex align-items-center justify-content-center'
                                    style='width:40px; height:40px; min-width:40px; min-height:40px;'>
                                @initial
                            </div>                        
                            <span class="fw-bolder mt-1">
                                @(char.ToUpper(@ViewBag.Username[0]) + @ViewBag.Username.Substring(1))
                                @(char.ToUpper(@ViewBag.Lastname[0]) + @ViewBag.Lastname.Substring(1))
                            </span> 
                        </div>  
                        <select class="form-select form-select-sm w-auto mt-1" name="Scope">
                            <option selected value="Public"><i class="bi bi-globe"></i> Public</option>
                            <option value="Friends"><i class="bi bi-people"></i> Friends</option>
                            <option value="Myself"><i class="bi bi-lock"></i> Only me</option>
                        </select>                    
                    </div>

                    <textarea id="textAreaBackground" class="form-control text-center mb-2" rows="5" placeholder="What's on your mind?" name="content"
                              style="resize: none; font-size: 1.1rem; font-weight : bold;"></textarea>
                    <button type="button" id="mainButton" data-action="PostColourBtn" class="btn btn-primary mb-2">Colour</button>
                    <div id="colourButton" class="d-none d-flex gap-1 mb-2">
                        <input type="hidden" id="selectedColor" name="selectedColor" />
                        <button type="button" class="btn btn-danger rounded-circle circle-btn" onclick="changeColor('red')"></button>
                        <button type="button" class="btn btn-success rounded-circle circle-btn" onclick="changeColor('green')"></button>
                        <button type="button" class="btn btn-primary rounded-circle circle-btn" onclick="changeColor('blue')"></button>
                        <button type="button" class="btn rounded-circle circle-btn" onclick="changeColor('white')" style="background-color : whitesmoke"></button>
                        <button type="button" class="btn rounded-circle circle-btn" onclick="changeColor('aqua')" style="background-color : aqua"></button>
                        <button type="button" class="btn rounded-circle circle-btn" onclick="changeColor('black')" style="background-color : black"></button>
                        <button type="button" class="btn rounded-circle circle-btn" onclick="changeColor('gold')" style="background-color : gold"></button>
                        <button class="btn btn-sm text-primary" type="button" data-action="HideColours" id="hideShownColourBtn">_Hide</button>
                    </div>
                    <div class="mb-3" id="imagePreviewContainer" style="display: none; max-height : 220px;">
                        <div class="border rounded p-2 position-relative" style="overflow-y: auto; max-height : 200px;">
                            <input type="hidden" name="pic" id="imagePic">
                            <img id="imagePreview" class="image img-fluid" style="width : 100%; object-fit: contain;" alt="image">
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2"
                                    onclick="clearImage()">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="border rounded p-3 mb-3">
                        <h6 class="mb-3">Add to your post</h6>
                        <div class="d-flex justify-content-around">
                            <label id="labelImageInput" class="btn btn-outline-secondary rounded-pill" title="Photo/Video">
                                <i class="bi bi-image text-success"></i>
                                <span class="ms-1">Photo</span>
                                <input type="file" id="imageInput" name="postImage" accept="image/*" class="d-none">
                            </label>
                            <button type="button" class="btn btn-outline-secondary rounded-pill" title="Tag Friends">
                                <i class="bi bi-person-badge text-primary"></i>
                                <span class="ms-1">Tag People</span>
                            </button>
                            <button type="button" class="btn btn-outline-secondary rounded-pill" title="Feeling">
                                <i class="bi bi-emoji-smile text-warning"></i>
                                <span class="ms-1">Feeling</span>
                            </button>
                            <button type="button" class="btn btn-outline-secondary rounded-pill" title="Location">
                                <i class="bi bi-geo-alt text-danger"></i>
                                <span class="ms-1">Location</span>
                            </button>
                        </div>
                    </div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary action-btn px-4">
                        <i class="bi bi-send me-2"></i>Post
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

}else{

  {
    ViewData["Title"] = "Error";
    Layout = null;
  }

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - ChatUp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
</head>
<body>
    <div class="container mb-5 mt-5">
        <div class="text-center py-5">
            <div class="display-1 text-muted mb-3">
                <i class="bi bi-chat-square-text"></i>
            </div>
            <h3 class="mb-3">Something Went Wrong!<br />We currently attending to the issue.</h3>
            <p class="text-muted mb-4">The issue is : @TempData["ErrorMessage"] </p>
            <button class="btn btn-primary btn-lg action-btn">
                <i class="bi bi-plus-circle me-2"></i>Refresh
            </button>
        </div>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - ChatUp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
</body>
</html>

}

