                                        <button class="btn btn-sm p-0 text-muted lh-sm">Reply</button>
                                    </div>
                                </div>
                                </li>
                            </ul>
                        </div>`);
                    form.reset();
                }else {
                    toastr.error("Failed to send a reply due to : ");
                }
            }catch (err) {
                toastr.error(`${err.message} or Network error. Try again.`);
            }
        },

        async ReplyOfReplyForm(e){
            const id = e.target.dataset.id;
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            const message = formData.get("Message");
            try 
            {
                const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                if (response.ok) {
                    let imageContent = '';
                    const initial = loggedInUserName.charAt(0).toUpperCase();
                    const fullUsernameComment = loggedInUserName.charAt(0).toUpperCase() + loggedInUserName.slice(1) + ' ' +
                                        loggedInLastName.charAt(0).toUpperCase() + loggedInLastName.slice(1);
                    if(loggedInUserProfile && loggedInUserProfile.trim() !== "") {
                        imageContent = `<img src="${loggedInUserProfile}" class="rounded-circle me-2" style="width: 32px; height: 32px;">`;
                    } else {
                        imageContent = `<div class="avatar rounded-circle me-2 bg-primary text-white" style="width: 32px; height: 32px;">
                                            ${initial}
                                        </div>`;
                    }

                    const visibilityCheck = document.getElementById(`replyOfBtn-${id}`);
                    const collapseElement = document.querySelector(`#replyOfView-${id}`);
                    if (collapseElement)
                    {
                        const collapseInstance = bootstrap.Collapse.getOrCreateInstance(collapseElement, { toggle: false });
                        collapseInstance.toggle();
                    }

                    const container = collapseElement;
                    container.insertAdjacentHTML("afterbegin", `
                        ${visibilityCheck ? "" : `<div class="view-data-btn" id="replyBtn-${id}"> <small>View 1 Replies</small> </div>`}
                        <div class="d-flex mb-2">
                            ${imageContent}
                            <ul class="list-unstyled">
                                <li>
                                    <div class="bg-light rounded p-2 flex-grow-1 text-break gap-2">
                                        <small class="fw-bold">${fullUsernameComment}</small>
                                        <p class="mb-1 small">${message}</p>
                                    </div>
                                </li>
                                <li>
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="text-muted small lh-sm flex-shrink-0 me-2">just now</span>
                                    <div class="ms-auto d-flex align-items-center gap-1 pe-2 flex-shrink-0">
                                        <button class="btn btn-sm p-0 text-muted lh-sm"> Like</button>
                                    </div>
                                    </div>
                                </li>
                            </ul>
                        </div>`);
                    form.reset();
                } else {
                    toastr.error("Failed to send a reply due to : ");
                }
            }catch (err) {
                toastr.error(`${err.message} or Network error. Try again.`);
            }

        }
    
    };


    document.addEventListener("click", function(event){
        const click = event.target.dataset.action;
        if(!click) return;
        const handler = eventListenerClickMethods[click];
        if(handler) handler(event);
    });

    document.addEventListener("input", function(event){
        const action = event.target.dataset.action;
        if(!action) return;
        const handler = eventListenerInputMethods[action];
        if(handler) handler(event);
    });

    document.addEventListener("submit", function(event){
        const submission = event.target.dataset.action;
        if(!submission) return;
        const handler = eventListenerSubmitMethods[submission];
        if(handler) handler(event);
    });


</script>
}

