@model Mvc_CRUD.Dto.UserProfileDTO;

@{
    ViewData["Title"] = "UserProfile";
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<link href="~/css/site.css" rel="stylesheet" />

<div class="container py-4">
        <div class="position-relative">
            <div class="dropdown">
            <button id="toggleDropDown" type="button" style="background:none; border:none; padding:0; cursor:pointer; display:block; width:100%;">
            @if (Model.UserCoverPicUrl != null && Model.UserCoverPicUrl?.Length > 0)
                {
                    <img src="@Model.UserCoverPicUrl" id="coverImage" class="img-fluid w-100" style="height: 450px; object-fit: cover; cursor : pointer;" alt="Cover Image">
                }
                else
                {
                    <div id="letterCoverImage" class="bg-secondary w-100" style="height: 400px; cursor : pointer; align-content : center;">
                        <div class="text-capitalize text-white fw-bolder h1"> @(char.ToUpper(Model.UserName[0]) + Model.UserName.Substring(1)) </div>
                        <div> <small class="text-white h4">Add a Cover Picture</small> </div>
                    </div>
                    <div id="updatedCoverImage"></div>
                }
            </button>
            <ul class="custom-menu" id="dropDownMenu">
                <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#viewCoverPic">View Cover Photo</a></li>
                <li><label class="dropdown-item" href="#">Change Cover Photo
                        <input type="file" id="coverInput" accept="image/*" class="d-none">  </label>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="#">Remove Cover Photo</a></li>
            </ul>
            </div>

            <div class="position-absolute" style="bottom: -70px; left: 30px; z-index : 1;">
                <div class="dropdown">
                    <button type="button" id="toggleProfileDropDown" style="background:none; border:none; padding:0; cursor:pointer; display:block; width:100%;">
                        @if (Model.UserProfilePicUrl != null && Model.UserProfilePicUrl.Length > 0)
                        {
                            <img src="@Model.UserProfilePicUrl" id="profileImage" class="rounded-circle border border-4 border-white update-profile-img"
                                 style="width: 150px; height: 150px; object-fit: cover; cursor : pointer" />
                        }
                        else
                        {
                            <div id="letterProfileImage" class='avatar rounded-circle bg-primary text-white d-flex align-items-center justify-content-center text-capitalize fw-bolder h2 profile-pic-phone-width'
                                 style='width:150px; height:150px; min-width:50px; min-height:50px;'>
                                @(!string.IsNullOrEmpty(Model.UserName) ? Model.UserName.Substring(0, 1).ToUpper() : "XX")
                            </div>
                            <div id="updatedProfileImage"></div>
                        }                        
                        <div class="camera-icon">
                            <i class="bi bi-camera-fill"></i>
                        </div>
                    </button>                    

                    <ul class="custom-profile-pic-dropdown" id="profileDropdownMenu">
                        <li selected><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#viewProfilePic">View Profile Picture</a></li>
                        <li><label class="dropdown-item" style="cursor : pointer">Change Profile Picture
                            <input type="file" id="picInput" accept="image/*" class="d-none"></label></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#">Remove Photo</a></li>
                    </ul>
                </div>

            </div>

        </div>

        <div class="mt-5 d-flex justify-content-between flex-wrap align-items-center">
            <div style="padding-left: 11.5rem">
                <h2 class="fw-bold mb-0">@(char.ToUpper(@Model.UserName[0]) + @Model.UserName.Substring(1)) @(char.ToUpper(@Model.LastName[0]) + @Model.LastName.Substring(1))</h2>
                <small class="text-muted">1,245 Friends</small>
            </div>

            <div class="d-flex gap-2 mt-3 mt-md-0">
                <a class="btn btn-primary px-4 rounded-pill" data-bs-toggle="modal" data-bs-target="#storyFormModal">Add to Story</a>
                <a href="@Url.Action("UpdateUserProfile", "Home")" onclick="test()" class="btn btn-light px-4 rounded-pill">Edit Profile</a>
            </div>
        </div>

        <hr />

        <ul class="nav nav-tabs mt-3">
            <li class="nav-item">
                <a class="nav-link active" href="#">Posts</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">About</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">Friends</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#">Photos</a>
            </li>
        </ul>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold">About</h5>
                        <p class="mt-3 mb-1"><strong>Location:</strong> @Model.Location</p>
                        <p class="mb-1"><strong>Work:</strong> @Model.JobTitle</p>
                        <p class="mb-1"><strong>Education:</strong> @Model.CollegeName</p>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Photos</h5>
                        <div class="row g-2">
                            <div class="col-4">
                                <img src="~/images/cover.png" class="w-100 rounded" />
                            </div>
                            <div class="col-4">
                                <img src="~/images/cover.png" class="w-100 rounded" />
                            </div>
                            <div class="col-4">
                                <img src="~/images/cover.png" class="w-100 rounded" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ********************************** Posts **************************** *@
            <div class="col-md-8">
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                        <img src="@Model.UserProfilePicUrl" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                            <input class="form-control rounded-pill" placeholder="What's on your mind?" />
                        </div>
                        <hr />
                        <div class="d-flex justify-content-around">
                            <button class="btn btn-light fw-bold">
                                <i class="bi bi-camera-video text-danger"></i> Live
                            </button>
                            <button class="btn btn-light fw-bold">
                                <i class="bi bi-images text-success"></i> Photo
                            </button>
                            <button class="btn btn-light fw-bold">
                                <i class="bi bi-emoji-smile text-warning"></i> Feeling
                            </button>
                        </div>
                    </div>
                </div>
                <div id="postContent"></div>
            </div>
        </div>

    </div>

    @* *******************Add to Story Button Pop-up*********************************** *@

    <div class="modal fade" id="storyFormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Update Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="/Home/SubmitForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" name="Name" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="Email" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    @* *******************View Profile Picture Pop-up*********************************** *@

    <div class="modal fade" id="viewProfilePic" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                    <div class="modal-body">
                        <img src="@Model.UserProfilePicUrl" class="post-image img-fluid " alt="Post image"
                             style="height : 450px; width : 500px">
                    </div>
            </div>
        </div>
    </div>

    @* *******************View Cover Picture Pop-up*********************************** *@

    <div class="modal fade" id="viewCoverPic" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <img src="@Model.UserCoverPicUrl" class="post-image img-fluid " alt="Post image"
                         style="height : 450px; width : 850px">
                </div>
            </div>
        </div>
    </div>


<script>
    document.addEventListener("DOMContentLoaded", function(){
        const dropdown = document.getElementById("toggleDropDown");
        const menu = document.getElementById("dropDownMenu");
        dropdown.addEventListener("click", function(e){
            e.stopPropagation();
            const menuDisplayState = window.getComputedStyle(menu).display === "none";
            menu.style.display = menuDisplayState ? "block" : "none";
            const firstItem = menu.querySelector("a");
            if (firstItem) {
                firstItem.focus();
            }
        });

        document.addEventListener("click", function () {
            menu.style.display = "none";
        });

        const profileDropdown = document.getElementById("toggleProfileDropDown");
        const profileMenu = document.getElementById("profileDropdownMenu");
        profileDropdown.addEventListener("click", function(e){
            e.stopPropagation();
            const menuDisplayState = window.getComputedStyle(profileMenu).display === "none";
            profileMenu.style.display = menuDisplayState ? "block" : "none";
            const firstItem = profileMenu.querySelector("a");
            if (firstItem) {
                firstItem.focus();
            }
        });

        document.addEventListener("click", function () {
            profileMenu.style.display = "none";
        });


    });

    fetch('/Home/UserPosts', {method: "GET", headers: { "X-Requested-With": "XMLHttpRequest" }  }).then(results =>{
        if(!results)
        {
            return document.getElementById('postContent').innerHTML =  `<div class="alert alert-danger text-center w-100">Error loading Posts. Please try again later.</div>`;
        }else{
            return results.json();
        }        
    }).then(res =>{
        const content = document.getElementById('postContent');
         if (res.length === 0)
              return content.innerHTML = ` <div class="alert alert-primary text-center w-100">No Posts found. Please create a post and try again.</div>`;
         content.innerHTML = '';
         res.forEach(post => {
                const firstLetter = post.userName?.charAt(0).toUpperCase() ?? "?";
                const username = post.userName.charAt(0).toUpperCase() + post.userName.slice(1) + ' ' + post.lastName.charAt(0).toUpperCase() + post.lastName.slice(1);
                const postInfo  =
                ` <div class="card shadow-sm border-0 rounded-4 mb-4 gap-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                    ${post.userImageUrl ?
                                        `<img src="${post.userImageUrl}" class="rounded-circle" style="width:45px;height:45px;object-fit:cover;" />`
                                              :  `<div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold" style="width:45px;height:45px;">
                                    ${firstLetter}   </div>` }
                                <div class="ms-3">
                                    <strong>${username}</strong>
                                    <div class="text-muted small">2 hours ago</div>
                                </div>
                            </div>
                            ${post.postBgColour ? ` <div class="post-bgcard"  style="background-color:${post.postBgColour};">
                                        <div class="post-bgtext">${post.content}</div>
                                        </div>` : `${post.content}`}
                            ${post.imageContentUrl ? `<img src="${post.imageContentUrl}" class="w-100 rounded mb-3" />` : ''}
                            <div class="d-flex justify-content-around">
                                <button class="btn btn-light w-100 me-2"><i class="bi bi-hand-thumbs-up"></i> Like</button>
                                <button class="btn btn-light w-100 me-2"><i class="bi bi-chat"></i> Comment</button>
                                <button class="btn btn-light w-100"><i class="bi bi-share"></i> Share</button>
                            </div>
                        </div>
                    </div>`;
                content.insertAdjacentHTML('beforeend', postInfo);
         });
    }); 
         

    document.getElementById("picInput").addEventListener("change", async function (event) {
        const file = event.target.files[0];
        if (file) {
             const formImg = new FormData();
             formImg.append("profileImage", file);
             const res = await fetch('/Home/UpdateProfilePicture', {method : "PATCH", body : formImg});
             const result = await res.json();
            if(result.success)
            {
                event = URL.createObjectURL(file);                
                const img = document.getElementById("profileImage");
                console.log("image content", img);
                if(img){
                    img.src = event;
                }else{
                    document.getElementById("letterProfileImage").classList.add("d-none");
                    document.getElementById("updatedProfileImage").innerHTML = `<img src="${event}" id="profileImage" class="rounded-circle border border-4 border-white update-profile-img"
                                                                            style="width: 150px; height: 150px; object-fit: cover; cursor : pointer" />`;           
                }
            }else
            {
                toastr.error(`Failed to change profile picture due to : ${result.message}`);
            }            
        }
    });

    document.getElementById("coverInput").addEventListener("change", async function (event) {
        const file = event.target.files[0];
        if (file) {
             const formImg = new FormData();
             formImg.append("coverImage", file);
             const res = await fetch('/Home/UpdateCoverPicture', {method : "PATCH", body : formImg});
             const result = await res.json();
            if(result.success)
            {
                event = URL.createObjectURL(file);
                const img = document.getElementById("coverImage");
                if(img){
                    img.src = event;
                }else{
                    document.getElementById("letterCoverImage").style.display = "none"; 
                    document.getElementById("updatedCoverImage").innerHTML = 
                       `<img src="${event}" id="coverImage" class="img-fluid w-100" 
                        style="height: 450px; object-fit: cover; cursor : pointer;" alt="Cover Image">`; 
                }                
            }else
            {
                toastr.error("Failed to change profile picture");
            }
        }
    });

</script>



